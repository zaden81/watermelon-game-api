# Neon Serverless Postgres connection string
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Server
PORT=3001
HOST=0.0.0.0

# CORS — portfolio frontend origin
CORS_ORIGIN=http://localhost:3000

